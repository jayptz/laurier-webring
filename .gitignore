# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Public raster images (large / many — keep locally; deploy still needs the exceptions below)
/public/**/*.png
/public/**/*.jpg
/public/**/*.jpeg
/public/**/*.webp
/public/**/*.gif
!/public/Old_Waterloo_Lutheran_Golden_Hawks.png
!/public/wlu-logo.png
!/public/Wilfrid-Laurier-University-logo-removebg-preview.png
